# KnightVision Environment Variables
# Copy this file to .env before running docker compose up --build
#   cp .env.example .env
#
# All variables are optional unless you want to use that provider.

# ── LLM provider API keys ────────────────────────────────────────────────────

# Groq Cloud LLM (free tier at console.groq.com)
GROQ_API_KEY=

# HuggingFace Inference API (free token at huggingface.co/settings/tokens)
HUGGINGFACE_API_KEY=

# ── Ollama (Docker networking) ───────────────────────────────────────────────
# The backend entrypoint patches config.yaml to use this hostname.
# Leave as "ollama" when using docker-compose; for local dev this has no effect.
OLLAMA_HOST=ollama

# ── Production / hosted deployment ──────────────────────────────────────────

# Override the default LLM provider at startup (ollama | groq | huggingface).
# Set to "groq" on Railway/Render where Ollama is not available.
LLM_DEFAULT_PROVIDER=ollama

# Comma-separated list of allowed CORS origins for the backend.
# Defaults to "*" (all origins) when not set.
# Example: https://knightvision.up.railway.app,https://your-frontend.vercel.app
ALLOWED_ORIGINS=

# Frontend build-time variable: hosted backend base URL.
# Set when deploying the frontend separately (Vercel/Netlify/Railway).
# Leave empty when using Docker Compose with Nginx proxy.
VITE_API_BASE_URL=
